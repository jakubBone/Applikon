# ===========================================
# EasyApply - Environment Configuration
# ===========================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# For production, create a separate .env.prod:
#   docker-compose --env-file .env.prod up -d
#
# Note: the frontend has its own .env.example in easyapply-frontend/

# -------------------------------------------
# Database (PostgreSQL)
# -------------------------------------------
POSTGRES_DB=easyapply_db
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_secure_password_here

# Backend datasource — required when running the backend locally (./mvnw spring-boot:run).
# When running via docker-compose these are built automatically from POSTGRES_* above.
DATABASE_URL=jdbc:postgresql://localhost:5432/easyapply_db
DATABASE_USERNAME=your_db_user
DATABASE_PASSWORD=your_secure_password_here

# -------------------------------------------
# Backend (Spring Boot)
# -------------------------------------------
# Active profile: local, dev, prod
SPRING_PROFILES_ACTIVE=local

# CORS — comma-separated allowed origins
# Dev:  http://localhost:5173,http://localhost
# Prod: https://your-domain.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost

# Frontend URL — used for OAuth2 redirect after successful Google login
# Dev:  http://localhost:5173
# Prod: https://your-domain.com
FRONTEND_URL=http://localhost:5173

# -------------------------------------------
# Google OAuth2 (REQUIRED — create credentials at https://console.cloud.google.com/)
# -------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -------------------------------------------
# JWT (optional — defaults shown)
# -------------------------------------------
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# -------------------------------------------
# File uploads (optional — default shown)
# -------------------------------------------
UPLOAD_DIR=uploads/cv
