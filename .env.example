# ===========================================
# EasyApply - Environment Configuration
# ===========================================
# Skopiuj ten plik do .env i dostosuj wartosci:
#   cp .env.example .env
#
# Dla produkcji stworz osobny plik .env.prod:
#   docker-compose --env-file .env.prod up -d

# -------------------------------------------
# Database (PostgreSQL)
# -------------------------------------------
POSTGRES_DB=easyapply_db
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_secure_password_here

# -------------------------------------------
# Backend (Spring Boot)
# -------------------------------------------
# Profile: dev, prod
SPRING_PROFILES_ACTIVE=dev

# CORS - dozwolone originy (oddzielone przecinkami)
# Dev: http://localhost:5173,http://localhost
# Prod: https://twoja-domena.pl
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost

# -------------------------------------------
# Frontend (Vite/React)
# -------------------------------------------
# Dev: http://localhost:8080/api
# Prod: https://api.twoja-domena.pl/api
VITE_API_URL=http://localhost:8080/api
