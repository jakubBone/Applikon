<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!--
        Import Spring Boot defaults (console colors, log levels).
        We extend them with MDC userId instead of writing the config from scratch.
    -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <!--
        %X{userId} — value from MDC under the "userId" key.
        If the user is not logged in (e.g. /api/auth/refresh), the field is empty.
        The ":-" separator means: use "anonymous" if the key does not exist.
    -->
    <property name="CONSOLE_LOG_PATTERN"
              value="%clr(%d{HH:mm:ss.SSS}){faint} %clr(${LOG_LEVEL_PATTERN:-%5p}) %clr([%X{userId:-anonymous}]){cyan} %clr(---){faint} %clr([%15.15t]){faint} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %m%n${LOG_EXCEPTION_CONVERSION_WORD:-%wEx}"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

    <!-- Reduce noise from Hibernate and Spring Security in logs -->
    <logger name="org.hibernate.SQL" level="DEBUG" additivity="false">
        <appender-ref ref="CONSOLE"/>
    </logger>
    <logger name="org.springframework.security" level="WARN"/>

</configuration>
